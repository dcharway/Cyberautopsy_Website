# Copy to .env.local. Do not commit .env.local.

# Shared HMAC secret for verifying session tokens issued by the marketing site.
# MUST be identical to cyberautopsy-site/.env.local.
SESSION_SECRET=change-me-to-a-long-random-string

# Where to redirect unauthenticated users (sign-in page on the marketing site).
MARKETING_URL=http://localhost:3000
