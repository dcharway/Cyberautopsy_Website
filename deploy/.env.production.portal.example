# cyberautopsy-portal/.env.local on the production VPS.
# Copy to cyberautopsy-portal/.env.local and replace REPLACE_ME.

# === Auth (shared with marketing site) ======================================
# MUST be identical to cyberautopsy-site/.env.local SESSION_SECRET.
SESSION_SECRET=REPLACE_ME_with_openssl_rand_hex_32

# === Where to send unauthenticated users for sign-in ========================
MARKETING_URL=https://cyberautopsy.org

# === Node runtime ===========================================================
NODE_ENV=production
