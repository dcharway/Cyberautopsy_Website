# cyberautopsy-site/.env.local on the production VPS.
# Copy to cyberautopsy-site/.env.local and replace REPLACE_ME values.

# === Auth (shared with portal) ==============================================
# Generate ONCE with:  openssl rand -hex 32
# MUST be identical in cyberautopsy-portal/.env.local.
SESSION_SECRET=REPLACE_ME_with_openssl_rand_hex_32

# === Cross-origin handoff ===================================================
PORTAL_URL=https://portal.cyberautopsy.org

# === WebAuthn relying party =================================================
# RP_ID = registrable domain. Covers any subdomain.
RP_ID=cyberautopsy.org
RP_ORIGIN=https://cyberautopsy.org

# === Form submission backend (optional, for /api/contact + /api/lead-magnet) =
# Sign up at resend.com, verify the cyberautopsy.org sender domain, paste key.
RESEND_API_KEY=
INTAKE_EMAIL=intake@cyberautopsy.com
INTAKE_FROM=CyberAutopsy Intake <intake@cyberautopsy.com>

# === Node runtime ===========================================================
NODE_ENV=production
