# Top-level .gitignore for the CyberAutopsy monorepo.
# Applies to both cyberautopsy-site/ and cyberautopsy-portal/.

# Node + Next.js build artifacts
node_modules/
.next/
out/
build/
dist/

# Local environment + persistence
.env*.local
.env
.data/

# Logs + caches
*.log
npm-debug.log*
yarn-debug.log*
.npm
.eslintcache
.cache/

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
*.swp
*.swo

# TypeScript build info (Next.js next-env.d.ts SHOULD be committed; do not ignore it)
*.tsbuildinfo

# Vercel
.vercel

# Duplicate of the hero video — the canonical copy lives in cyberautopsy-site/public/
/cyberautopsy_video.mp4

# Generated coverage / test artifacts
coverage/
.nyc_output/

# Local lockfile noise from package managers we don't use
yarn.lock
pnpm-lock.yaml
bun.lockb
