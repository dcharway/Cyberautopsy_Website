# Copy to .env.local and fill in. Do not commit .env.local.

# Resend email dispatch (used by /api/contact and /api/lead-magnet).
# Sign up at resend.com → API Keys → create a new key.
RESEND_API_KEY=

# Where form submissions are routed (the firm's intake mailbox).
INTAKE_EMAIL=intake@cyberautopsy.com

# The "From" header used on outbound intake emails.
# Must be a Resend-verified sender on your domain.
INTAKE_FROM=CyberAutopsy Intake <intake@cyberautopsy.com>

# Shared HMAC secret for the session token handed off to the GRC portal.
# MUST be identical in cyberautopsy-portal/.env.local. Use a long random string.
SESSION_SECRET=change-me-to-a-long-random-string

# Where the marketing site sends the user after MFA (must include port if not 80/443).
PORTAL_URL=http://localhost:3100

# WebAuthn relying-party config. For localhost these are correct.
RP_ID=localhost
RP_ORIGIN=http://localhost:3000
